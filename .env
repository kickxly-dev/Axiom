# ============================================================
#  Axiom AI Brain - Environment Variables
# ============================================================

# --- Run Mode ---
# desktop  → interactive terminal chat (no Discord required)
# discord  → Discord bot (default)
MODE=discord

# --- Google AI Studio Settings ---
# Get your free API key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Model to use — see https://ai.google.dev/gemini-api/docs/models/gemini
# Recommended options: gemini-2.0-flash (default), gemini-1.5-flash, gemini-1.5-pro
GOOGLE_AI_MODEL=gemini-2.0-flash

# --- Discord Bot Token (required for Discord mode) ---
# Get yours at: https://discord.com/developers/applications
# 1. Create a new Application
# 2. Go to "Bot" tab and click "Add Bot"
# 3. Under "Token", click "Reset Token" to copy your bot token
DISCORD_TOKEN=your_discord_bot_token_here

# --- Discord Client ID (optional) ---
# Found on your Application's "General Information" page (Application ID).
# Not required to run the bot, but useful if you later add slash command registration.
DISCORD_CLIENT_ID=your_discord_client_id_here

# --- Bot Behavior ---
# The "personality" / system prompt for your AI brain
# You can override this to give Axiom a custom name, tone, or role.
SYSTEM_PROMPT=You are Axiom, a sharp and friendly AI assistant. You're straightforward, helpful, and sound like a real person — not a textbook. Use tools whenever they help you get the job done.

# Response verbosity: "concise" (default) or "detailed"
#   concise  → short, to-the-point replies — like a smart friend texting back
#   detailed → thorough answers with context, steps, and bullet points
RESPONSE_VERBOSITY=concise

# Maximum number of tool-call rounds per message (prevents infinite loops)
MAX_TOOL_ROUNDS=5

# Maximum number of conversation turns to keep in memory per channel/session
# Older turns are pruned to keep requests fast and within context limits
MAX_HISTORY_TURNS=20

# --- Private / Access Control ---
# Keep Axiom private by restricting who can use it.
# Leave any setting empty (or remove the line) to allow unrestricted access for that scope.

# Your Discord user ID — always has access regardless of the lists below.
# Right-click yourself in Discord (with Developer Mode on) → "Copy User ID".
OWNER_ID=

# Comma-separated list of Discord user IDs allowed to use the bot.
# Example: ALLOWED_USER_IDS=123456789012345678,987654321098765432
# Leave empty to allow all users (in allowed guilds, if set).
ALLOWED_USER_IDS=

# Comma-separated list of Discord server (guild) IDs where the bot will respond.
# Example: ALLOWED_GUILD_IDS=111122223333444455,666677778888999900
# Leave empty to allow all servers.
ALLOWED_GUILD_IDS=
