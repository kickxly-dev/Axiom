# ============================================================
#  Axiom AI Brain - Environment Variables
# ============================================================

# --- Discord Bot Token ---
# Get yours at: https://discord.com/developers/applications
# 1. Create a new Application
# 2. Go to "Bot" tab and click "Add Bot"
# 3. Under "Token", click "Reset Token" to copy your bot token
DISCORD_TOKEN=your_discord_bot_token_here

# --- Discord Client ID (optional) ---
# Found on your Application's "General Information" page (Application ID).
# Not required to run the bot, but useful if you later add slash command registration.
DISCORD_CLIENT_ID=your_discord_client_id_here

# --- Groq API Key (FREE) ---
# Get yours at: https://console.groq.com/keys
# Groq offers a generous free tier — no credit card required!
GROQ_API_KEY=your_groq_api_key_here

# --- Groq Model (optional) ---
# Default: llama3-8b-8192 (fast & free)
# Other options: mixtral-8x7b-32768 (more capable), llama3-70b-8192 (most powerful)
GROQ_MODEL=llama3-8b-8192

# --- Bot Behavior ---
# The "personality" / system prompt for your AI brain
SYSTEM_PROMPT=You are Axiom, a highly intelligent AI assistant and agent. You are helpful, concise, and proactive. When users ask you to do something, you use available tools to fulfill their request. Always explain what you are doing.

# Maximum number of tool-call rounds per message (prevents infinite loops)
MAX_TOOL_ROUNDS=5
