# ============================================================
#  Axiom AI Brain - Environment Variables
# ============================================================

# --- Run Mode ---
# desktop  → interactive terminal chat (no Discord required)
# discord  → Discord bot (default)
MODE=discord

# --- Ollama Settings ---
# URL of your local Ollama server (default: http://localhost:11434)
OLLAMA_ENDPOINT=http://localhost:11434

# Model to use — must be pulled first: ollama pull phi3:mini
# Other options: phi3:medium, llama3, mistral, gemma, etc.
OLLAMA_MODEL=phi3:mini

# --- Discord Bot Token (required for Discord mode) ---
# Get yours at: https://discord.com/developers/applications
# 1. Create a new Application
# 2. Go to "Bot" tab and click "Add Bot"
# 3. Under "Token", click "Reset Token" to copy your bot token
DISCORD_TOKEN=your_discord_bot_token_here

# --- Discord Client ID (optional) ---
# Found on your Application's "General Information" page (Application ID).
# Not required to run the bot, but useful if you later add slash command registration.
DISCORD_CLIENT_ID=your_discord_client_id_here

# --- Bot Behavior ---
# The "personality" / system prompt for your AI brain
# You can override this to give Axiom a custom name, tone, or role.
SYSTEM_PROMPT=You are Axiom, a sharp and friendly AI assistant. You're straightforward, helpful, and sound like a real person — not a textbook. Use tools whenever they help you get the job done.

# Response verbosity: "concise" (default) or "detailed"
#   concise  → short, to-the-point replies — like a smart friend texting back
#   detailed → thorough answers with context, steps, and bullet points
RESPONSE_VERBOSITY=concise

# Maximum number of tool-call rounds per message (prevents infinite loops)
MAX_TOOL_ROUNDS=5
