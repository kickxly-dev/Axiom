# ============================================================
#  Axiom AI Platform - Environment Variables
# ============================================================

# --- Run Mode ---
# discord  → Discord bot (default)
# desktop  → interactive terminal chat (no Discord required)
# api      → HTTP API server (port 3000 by default)
MODE=discord

# ============================================================
#  PRIMARY PROVIDER — OpenRouter
#  Get a free API key at: https://openrouter.ai/keys
#  OpenRouter gives access to Gemini, GPT-4o, Claude, Mistral
#  and many other models — no Google billing required.
# ============================================================

# Your OpenRouter API key (takes priority over Google AI when set)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use via OpenRouter — see https://openrouter.ai/models
# Free options:   google/gemini-2.0-flash-exp:free
#                 meta-llama/llama-3.1-8b-instruct:free
# Paid options:   google/gemini-2.5-pro  |  openai/gpt-4o  |  anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Optional: override the OpenRouter base URL (default shown below)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Provider retry settings (auto-retry on 429 / 5xx)
# PROVIDER_MAX_RETRIES=3
# PROVIDER_RETRY_BASE_MS=1000

# ============================================================
#  FALLBACK PROVIDER — Google AI Studio
#  Only used when OPENROUTER_API_KEY is not set.
#  Get a key at: https://aistudio.google.com/app/apikey
# ============================================================

GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Gemini model to use when falling back to Google AI Studio
# Available models: gemini-2.0-flash (recommended), gemini-2.5-flash, gemini-2.5-pro
GOOGLE_AI_MODEL=gemini-2.0-flash

# ============================================================
#  HTTP API SERVER  (MODE=api)
# ============================================================

# Port for the HTTP API server
API_PORT=3000

# ============================================================
#  WEB CLIENT SERVER  (npm run start:web)
# ============================================================

# Port for the static web client
WEB_PORT=8080

# ============================================================
#  MEMORY / PROFILES  (SQLite)
# ============================================================

# Path to the SQLite database file.
# Default: ~/.axiom/axiom.db (created automatically)
# DB_PATH=/path/to/axiom.db

# ============================================================
#  CLI CLIENT  (npm run start:cli)
# ============================================================

# User ID used by the CLI client for memory and persona storage.
# Change this if you run multiple users on the same machine.
CLI_USER_ID=cli-user

# ============================================================
#  DISCORD BOT  (MODE=discord)
# ============================================================

# Your Discord bot token — get it at: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID (optional, not required to run the bot)
DISCORD_CLIENT_ID=your_discord_client_id_here

# ============================================================
#  BOT / AGENT BEHAVIOUR
# ============================================================

# System prompt override (leave blank to use the built-in Axiom prompt)
SYSTEM_PROMPT=

# Response verbosity: "concise" (default) or "detailed"
#   concise  → short, to-the-point replies
#   detailed → thorough answers with context, steps, and bullet points
RESPONSE_VERBOSITY=concise

# Maximum number of tool-call rounds per message (prevents infinite loops)
MAX_TOOL_ROUNDS=5

# Maximum number of conversation turns to keep in memory per channel/session
MAX_HISTORY_TURNS=20

# ============================================================
#  ACCESS CONTROL  (Discord)
# ============================================================

# Your Discord user ID — always has access regardless of the lists below.
OWNER_ID=

# Comma-separated list of Discord user IDs allowed to use the bot.
# ALLOWED_USER_IDS=123456789012345678,987654321098765432

# Comma-separated list of Discord server (guild) IDs where the bot will respond.
# ALLOWED_GUILD_IDS=111122223333444455,666677778888999900

