{
  "name": "axiom-ai-agent",
  "version": "2.0.0",
  "description": "Axiom — a pro AI agent desktop app powered by local Ollama with streaming, tools, and a clean minimal UI",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "desktop": "MODE=desktop node src/index.js",
    "app": "electron .",
    "app:dev": "NODE_ENV=development electron ."
  },
  "keywords": [
    "discord",
    "ai",
    "bot",
    "ollama",
    "phi3",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7"
  },
  "overrides": {
    "undici": "^6.24.1"
  },
  "devDependencies": {
    "electron": "^41.1.0"
  }
}
